# KILN Environment Variables
# Copy to .env.local and fill in the values

# Polar.sh
POLAR_API_KEY=polar_live_xxxxxxxxxxxx
POLAR_ORGANIZATION_ID=org_xxxxxxxxxxxx
POLAR_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
NEXT_PUBLIC_POLAR_PUBLISHABLE_KEY=pk_xxxxxxxxxxxx

# Price IDs (from Polar dashboard)
POLAR_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxx
POLAR_PRICE_PRO_ANNUAL=price_xxxxxxxxxxxx
POLAR_PRICE_TEAM_MONTHLY=price_xxxxxxxxxxxx
POLAR_PRICE_TEAM_ANNUAL=price_xxxxxxxxxxxx
NEXT_PUBLIC_POLAR_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxx
NEXT_PUBLIC_POLAR_PRICE_PRO_ANNUAL=price_xxxxxxxxxxxx
NEXT_PUBLIC_POLAR_PRICE_TEAM_MONTHLY=price_xxxxxxxxxxxx
NEXT_PUBLIC_POLAR_PRICE_TEAM_ANNUAL=price_xxxxxxxxxxxx

# Database (Neon/Supabase/Railway)
DATABASE_URL=postgresql://user:password@host:5432/kiln

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxx

# App
NEXT_PUBLIC_APP_URL=https://kiln.build
AUTH_SECRET=your-auth-secret-min-32-chars

# Ops team (comma-separated emails)
OPS_TEAM_EMAILS=tyler@kiln.build,hoss@kiln.build
