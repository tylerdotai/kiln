13:["$","h2",null,{"style":{"fontFamily":"var(--font-headline)","fontSize":"1.2rem","fontWeight":600,"color":"var(--color-text)","marginTop":36,"marginBottom":12},"children":"7. Data Security"}]
14:["$","p",null,{"style":{"marginBottom":16},"children":"We use industry-standard encryption (TLS 1.2+ in transit, AES-256 at rest), access controls, and regular security audits. No system is perfectly secure, but we take reasonable measures to protect your data."}]
